# ============================================================
# USDT TRC20 Payment Gateway — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Server
PORT=4000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=usdt_gateway

# ── JWT ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret
JWT_EXPIRES_IN=8h

# ── Admin Account (used in seed script) ───────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe!2024

# ── Encryption (for private keys at rest) ─────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_32_byte_hex_key

# ── Treasury Wallet (HIDDEN — never exposed via API) ──────
# This is your Ownbit or cold-storage wallet address.
TREASURY_ADDRESS=T_YOUR_OWNBIT_TRON_ADDRESS_HERE

# ── TronGrid / Network ────────────────────────────────────
# Get a free TronGrid key at https://www.trongrid.io/
# NOTE: TronGrid API keys are for mainnet only.
#       The Nile testnet (api.nileex.io) does NOT require an API key.
#       Leave TRONGRID_API_KEY blank when using Nile.
TRONGRID_API_KEY=your_trongrid_api_key

# ── Choose ONE network block below ────────────────────────

# MAINNET (production)
TRON_FULL_NODE=https://api.trongrid.io
USDT_CONTRACT_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# NILE TESTNET (recommended for testing)
# Faucet: https://nileex.io/join/getJoinPage  (2000 TRX + 50000 USDT per day, no signup)
# Explorer: https://nile.tronscan.org
# No API key needed.
#TRON_FULL_NODE=https://api.nileex.io
#USDT_CONTRACT_ADDRESS=TXYZopYRdj2D9XRtbG411XZZ3kM5VkAeBf

# SHASTA TESTNET (alternative)
# Faucet via Tron Discord bot: !shasta_usdt <address>
# Explorer: https://shasta.tronscan.org
#TRON_FULL_NODE=https://api.shasta.trongrid.io
#USDT_CONTRACT_ADDRESS=TG3XXyExBkPp9nzdajDZsozEu4BkaSJozs

# ── Monitoring ────────────────────────────────────────────
# How often (ms) to poll wallets for new transactions
POLL_INTERVAL_MS=30000

# Minimum confirmations to mark a tx as Confirmed
MIN_CONFIRMATIONS=20

# ── CORS ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
